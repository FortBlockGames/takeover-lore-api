# .env.example — Copy to .env and fill in values
# cp .env.example .env

# Server
PORT=3001
NODE_ENV=development

# JWT for session tokens
JWT_SECRET=change-this-to-a-random-64-char-string

# Avalanche
AVAX_RPC_URL=https://api.avax.network/ext/bc/C/rpc
AVAX_CHAIN_ID=43114
# For testnet:
# AVAX_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
# AVAX_CHAIN_ID=43113

# Glacier API (Avalanche NFT indexer)
GLACIER_API_URL=https://glacier-api.avax.network

# TAKEOVER NFT contract addresses (update when deployed)
CONTRACT_WEAPONS=0x0000000000000000000000000000000000000001
CONTRACT_ARMOR=0x0000000000000000000000000000000000000002
CONTRACT_FACTION=0x0000000000000000000000000000000000000003
CONTRACT_EFFECTS=0x0000000000000000000000000000000000000004
CONTRACT_VEHICLES=0x0000000000000000000000000000000000000005
CONTRACT_COSMETICS=0x0000000000000000000000000000000000000006

# CDN for asset URLs in manifest responses
CDN_BASE_URL=https://cdn.playtakeover.com

# Redis (optional — falls back to in-memory if not set)
# REDIS_URL=redis://localhost:6379

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGINS=http://localhost:3000,https://playtakeover.com
